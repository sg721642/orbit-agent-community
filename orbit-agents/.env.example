# ORBIT — AgentField Backend Configuration
# Copy this file to .env and fill in your API key.
# DO NOT commit .env to git.

# === LLM Provider ===
# Google Gemini (free tier via Google AI Studio: https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# LiteLLM model string for Gemini 2.5 Flash (free tier, fast)
LLM_MODEL=gemini/gemini-2.5-flash

# === AgentField Control Plane ===
AGENTFIELD_SERVER=http://localhost:8080

# === Agent Ports ===
ONBOARDING_AGENT_PORT=8001
MODERATION_AGENT_PORT=8002
EVENT_AGENT_PORT=8003
INSIGHTS_AGENT_PORT=8004
